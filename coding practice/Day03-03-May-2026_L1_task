# Kubernetes - create replicaset with 3 replicas

apiVersion: apps/v1
kind: ReplicaSet
metadate:
  name: pathnex-replicaset
spec:
  replicas: 3
  selector:
    matchedlabels:
      app: pathnex-app
  template:
    metadate:
      labels:
        app: pathnex-app
    spec:
      containers:
        - name: app
	  image: nginx
	  ports:
	     - conmtainerPort: 80
