# Terraform - EC2 Instance (t3.medium)

provider "aws" {
  region = "us-east-1"
}

resource "aws_instance" "PathnexEC2" {
  ami = "ami-abcd1234abcd1234"
  instance_type = "t3.medium"

  tags = {
    Name = "PathnexEC2"
  }
}
