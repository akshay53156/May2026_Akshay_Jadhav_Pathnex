# Ansible : install apache and Start Service

- name: Install Apache and Start Service
  hosts: all
  become: yes

  tasks:
    - name: Install apache
      yum:
        name: httpd
	status: present

    - name: Start service
      service:
        name: httpd
	state: started
	enabled: yes
