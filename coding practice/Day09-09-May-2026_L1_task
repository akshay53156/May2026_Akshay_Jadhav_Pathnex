# Jenkins Pipeline — Archive Artifacts
pipeline {
  agent any

  environment {
    INSTITUTE_NAME = "Pathnex"
  }

  stages {
    stage ('checkout') {
      steps {
         git url: "http://github.com/Pathnex/sample-java-code.git"
      }
    }

    stage ('Build') {
      steps {
         sh 'mvn clean package'
      }
    }

    stage ('Archive') {
      steps {
         archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
      }
    }
  }
}

