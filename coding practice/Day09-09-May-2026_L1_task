# GitLab CI — Artifacts

stages:
  - build

build:
  stage: build
  image: maven:3.8.1-jdk-17
  script:
    - git clone http://github.com/Pathnex/sample-java-code.git
    - cd sample-java-code
    - mvn clean package
  artifacts:
    paths:
      - target/*.jar
    expire_in: 1 week


















