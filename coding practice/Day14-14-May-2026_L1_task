# Terraform — Create EC2 (any instance type)
`
- VPC
- Subnet
- Internet gateway
- Route table
- EC2 (c5.xlarge / r5.2xlarge / r6i.4xlarge / c6i.8xlarge / c6a.12xlarge)

provider "aws" {
  region = "us-east-1"
}

resource "aws_vpc" "PathnexVPC" {
  cidr_block = "192.168.0.0/16"

  tags = {
    Name = "PathnexVPC"
  }
}

resource "aws_subnet" "PathnexVPCSubnet" {
  vpc_id      = aws_vpc.PathnexVPC.id
  cidr_block  = "192.168.1.0/24"
  map_public_ip_on_launch = true

  tags = {
    Name = "PathnexVPCSubnet"
  }
}

resource "aws_internet_gateway" "PathnexIG" {
  vpc_id = aws_vpc.PathnexVPC.id
  
  tags = {
    Name = "PathnexIG"
  }
}

resource "aws_route_table" "PathnexRT" {
  vpc_id = aws_vpc.PathnexVPC.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.PathnexIG.id
  }

  tags = {
    Name = "PathnexRT"
  }
}

resource "aws_route_table_association" "example" {
  subnet_id      = aws_subnet.PathnexVPCSubnet.id
  route_table_id = aws_route_table.PathnexRT.id
}

resource "aws_instance" "PathnexEC2Day14" {
  ami            = "ami-0236922087fa98b6e"
  subnet_id      = aws_subnet.PathnexVPCSubnet.id
  instance_type  = "t3.small"

  vpc_security_group_ids = [aws_security_group.allow_ssh.id]

  tags = {
    Name = "PathnexEC2Day14"
  }
}

resource "aws_security_group" "allow_ssh" {
  name        = "allow_ssh"
  description = "Allow SSH inbound traffic and all outbound traffic"
  vpc_id      = aws_vpc.PathnexVPC.id

  tags = {
    Name = "allow_ssh"
  }
}

resource "aws_vpc_security_group_ingress_rule" "allow_ssh_ipv4" {
  security_group_id = aws_security_group.allow_ssh.id
  cidr_ipv4         = "0.0.0.0/0"
  from_port         = 22
  ip_protocol       = "tcp"
  to_port           = 22
}

resource "aws_vpc_security_group_ingress_rule" "allow_http_ipv4" {
  security_group_id = aws_security_group.allow_ssh.id

  cidr_ipv4   = "0.0.0.0/0"
  from_port   = 80
  to_port     = 80
  ip_protocol = "tcp"
}

resource "aws_vpc_security_group_egress_rule" "allow_all_traffic_ipv4" {
  security_group_id = aws_security_group.allow_ssh.id
  cidr_ipv4         = "0.0.0.0/0"
  ip_protocol       = "-1" # semantically equivalent to all ports
}






# Scheduled Pipelines

# Jenkins Pipeline — Scheduled Build
# You will learn how to **schedule a Jenkins pipeline using cron**.

pipeline {
    agent any
    environment {
        INSTITUTE_NAME = "Pathnex"
    }
    triggers {
        cron('H 2 * * *') // every day at 2 AM
    }
    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Pathnex/sample-java-app.git'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }
    }
}

# GitLab CI — Scheduled Pipeline
