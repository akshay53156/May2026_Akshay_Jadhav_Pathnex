#  Terraform — Create S3 Bucket

provider "aws" {
  region = "us-east-1"
}

resource "aws_s3_bucket" "PathnexS3" {
  bucket = "Pathnex-Devops-Bucket"

  tags = {
    Name = "PathnexS3Bucket"
  }
}

