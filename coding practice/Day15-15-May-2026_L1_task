# Ansible — Install Java & Set JAVA_HOME

- name: Install Java and set JAVA_HOME
  hosts: all
  become: yes

  tasks:
   - name: Install OpenJDK
     yum:
       name: java-11-openjdk
       state: present

   - name: Set JAVA_HOME
     lineinfile:
       path: /etc/profile
       line: 'EXPORT JAVA_HOME=/usr/lib/jvm/java-11-openjdk'

