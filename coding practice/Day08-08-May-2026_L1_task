# Terraform — Create VPC + Subnet

provider "aws" {
  region = "us-east-1"
}

resource "aws_vpc" "PathnexVPC" {
  cidr_block = "10.0.0.0/16"

  tags = {
    Name = "Pathnex-VPC"
  }
}

resource "aws_subnet" "PathnexWebAppSubnet" {
  vpc_id = aws_vpc.PathnexVPC.id
  cidr_block = "10.0.1.0/24"
  map_public_ip_on_launch = true

  tags = {
    Name = "Pathnex-Subnet"
  }
}

# Kubernetes — Add Liveness & Readiness Probes

apiVersion: v1
kind: Pod
metadata:
  name: Pathnex-probe-app
spec:
  containers:
    - name: web
      image: nginx
      livenessProbe:
        httpGet:
	  path: /
	  port: 80
	initialDelaySeconds: 5
      readinessProbe:
        httpGet:
	  path: /
	  port: 80
	initialDelaySeconds: 5
