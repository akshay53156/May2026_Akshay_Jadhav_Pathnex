# Ansible — Install Packages Using Variables

- name: Install packages
  hosts: all
  become: yes
  
  vars:
    pathnex_packages:
      - tree
      - vim
      - unzip

  tasks:
    - name: Install required packages
      yum:
        name: "{{pathnex_packages}}"
	state: present

