#Kubernetes — Resource Limits

apiVersion: v1
kind: Pod
metadata:
  name: pathnex-limited-pod
spec:
  containers:
    - name: app
      image: nginx
      resources:
        limits:
	  memory: "256Mi"
	  cpu: "500M"

