# Terraform — EC2 with User Data (c6a.12xlarge)

provider "aws" {
  region: "us-east-1"
}

resource "aws_instance" "pathnex" {
  ami = "ami-abcd1234abcd1234"
  instance_type = "c6a.12xlarge"
  
  user_date = <<EOF
  #!/bin/bash
  yum install -y httpd
  systemctl start httpd
  EOF

  tags = {
    Name = "PathnexEC2"
  }
}
