# Ansible: Install Maria DB

- name: Install MariaDB
  hosts: all
  become: true

  tasks:
   - name: Install MariaDB
     yum:
         name: mariadb-server
         state: present

   - name: Start MariaDB
     yum:
         name: mariadb
	 state: started
	 enabled: yes
