# Terraform: Output public ip

provider "aws" {
  region = "us-east-1"
}


resource "aws_instance" "PathnexEC2" {
  ami = "ami-abcd1234abcd1234"
  instance_type = ""

  tags = {
    Name = "PathnexEC2"
  }
}

output "aws_instance_ip" {
  value = aws_instance.PathnexEC2.public_ip
}
