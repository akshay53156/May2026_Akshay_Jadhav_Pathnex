# Jenkins pipeline: email notification

pipeline {
  agent any {

  environment {
    INSTITUTE_NAME = "Pathnex"
  }
    stages {
      stage ('Checkout') {
        steps {
          git url "http://github.com/Pathnex/sample-java-code.git
	}
      }

      stage ('Build') {
        steps {
 	  sh 'mvn clean compile'
        }
      }
    }
    post {
      success {
        mail to: 'teams@pathnex.com'
	subject: "SUCCESS: Build #${env.BUILD_NUMBER}"
	body: "Build completed successfully for $INSTITUTE_NAME"

      }
      failure {
	mail to: 'teams@pathnex.com'
	subject: 'FAILURE: Build #${env.BUILD_NUMBER}'
	body: 'Buils failed for $INSTITUTE_NAME'
      }
    
    }
  }
}

