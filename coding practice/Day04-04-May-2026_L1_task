# Ansible - Install multiple packages

- name: Install multiple packages
  hosts: all
  become: yes

  tasks:
    - name: Install tools

      yum: 
        name:
	  - git
	  - wget
	  state: present

# Terraform — EC2 with Key Pair (c6i.8xlarge)

provider "aws" {
  region: "us-east-1"
}

resource "aws_key_pair" "PathnexKey" {
  key_name: "PathnexKey"
  public_key: "ssh-rsa AAAA...."
}

resource "aws_instance" "PathnexEC2" {
  ami: "ami-abcd1234abcd1234"
  instance_type: "c6i.8xlarge"
  count: 1
  key_name: aws_key_pair.PathnexKey.key_name

  tags = {
    Name = "Pathnex-EC2"
  }
}

# Kubernetes — Create ClusterIP Service

apiVersion: v1
kind: Service
metadata:
  name: pathnex-service
spec:
  selector:
    app: pathnex-app
  ports:
    - port: 80
      targetPort: 80

# Jenkins Pipeline — Parallel Build & Test
pipeline {
  agent any
  stages {
    stage ('Parallel Tasks') {
      parallel {
        stage ('Build') {
          steps {
             sh 'mvn clean compile'
	  }
	}
	stage ('Test') {
          steps {
             sh 'mvn test'
          }
        }
      }
    }
  }
}

# GitLab CI — Parallel Jobs


stages:
  - build-test

maven-build:
  stage: build-test 
  image: maven:3.8.1-jdk-17
  script:
    - git clone http://github.com/pathnex/sample-java-code.git
    - cd sample-java-code
    - mvn clean compile
  parallel: 1

maven-test:
  stage:build-test
  image: maven:3.8.1-jdk-17
  script:
    - cd sample-java-code
    - mvn test
  parallel: 1



















