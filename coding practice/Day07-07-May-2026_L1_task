2. Terraform: EC2 (choose any Pathnex instance)
provider "aws" {
  region = "us-east-1"
}

resource "aws_instance" "PathnexEC2" {
  ami = "ami-abcd1234abcd1234"
  instance_type = "t3.micro"
  count = 1

  tags = {
    Name = "Pathnex"
  }
}

3. Kubernetes: Deployment 2 replicas
apiVersion: apps/v1
kind: Deployment
metadata:
  name: "Pathnex-app"
spec:
  replicas: 2
  selector:
    matchLabels:
        app: "Pathnex-app"
  
  template:
    metadate:
      labels:
        app: "Pathnex-app"
    spec:
      containers:
        - name: nginx
	  image: nginx
	  ports:
	    containerPort: 80


